@@ -620,6 +620,7 @@
 	};
 
 	i2c1 {
+		u-boot,dm-pre-reloc;
 		i2c1m0_xfer: i2c1m0-xfer {
 			rockchip,pins =
 				/* i2c1_scl_m0 */
@@ -637,6 +638,7 @@
 		};
 
 		i2c1m2_xfer: i2c1m2-xfer {
+			u-boot,dm-pre-reloc;
 			rockchip,pins =
 				/* i2c1_scl_m2 */
 				<0 RK_PD4 9 &pcfg_pull_none_smt>,
diff -uNr u-boot-mixtile_new/arch/arm/dts/rockchip-pinconf.dtsi u-boot-mixtile/arch/arm/dts/rockchip-pinconf.dtsi
--- u-boot-mixtile_new/arch/arm/dts/rockchip-pinconf.dtsi	2023-11-20 14:53:16.682416840 +0000
+++ u-boot-mixtile/arch/arm/dts/rockchip-pinconf.dtsi	2023-11-20 14:53:43.762803565 +0000
@@ -267,6 +267,7 @@
 	};
 
 	pcfg_pull_none_smt: pcfg-pull-none-smt {
+		u-boot,dm-pre-reloc;
 		bias-disable;
 		input-schmitt-enable;
 	};
