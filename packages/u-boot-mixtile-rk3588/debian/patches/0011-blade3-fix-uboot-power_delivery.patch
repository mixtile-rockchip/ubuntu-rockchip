diff -uNr u-boot-mixtile_new/arch/arm/dts/rk3588-blade3.dts u-boot-mixtile/arch/arm/dts/rk3588-blade3.dts
--- u-boot-mixtile_new/arch/arm/dts/rk3588-blade3.dts	2023-11-20 14:53:16.802418563 +0000
+++ u-boot-mixtile/arch/arm/dts/rk3588-blade3.dts	2023-11-20 14:53:43.758803509 +0000
@@ -8,6 +8,7 @@
 #include "rk3588.dtsi"
 #include "rk3588-u-boot.dtsi"
 #include <dt-bindings/input/input.h>
+#include "dt-bindings/usb/pd.h"
 
 / {
 	model = "Mixtile Blade 3";
@@ -87,26 +88,62 @@
 
 &i2c1 {
 	status = "okay";
-
+	u-boot,dm-pre-reloc;
 	clock-frequency = <400000>;
 	i2c-scl-rising-time-ns = <160>;
 	i2c-scl-falling-time-ns = <30>;
+	pinctrl-names = "default";
+	pinctrl-0 = <&i2c1m2_xfer>;
 
 	usbc1: fusb302@22 {
+		u-boot,dm-pre-reloc;
 		compatible = "fcs,fusb302";
 		reg = <0x22>;
 		interrupt-parent = <&gpio0>;
 		interrupts = <RK_PC6 IRQ_TYPE_LEVEL_LOW>;
+		//fcs,int_n = <&gpio0 RK_PC6 IRQ_TYPE_LEVEL_LOW>;
 		pinctrl-names = "default";
 		pinctrl-0 = <&usbc1_int>;
 		vbus-supply = <&vbus5v0_typec1>;
 		status = "okay";
+
+		usb_con1: connector {
+			u-boot,dm-pre-reloc;
+			status = "okay";
+			compatible = "usb-c-connector";
+			label = "USB-C";
+			data-role = "dual";
+			power-role = "dual";
+			try-power-role = "sink";
+			op-sink-microwatt = <15000000>;
+			sink-pdos =
+				// <PDO_FIXED(5000, 3000, PDO_FIXED_USB_COMM)>;
+				<PDO_FIXED(5000, 1000, PDO_FIXED_USB_COMM)
+				PDO_VAR(5000, 20000, 1000)
+				PDO_PPS_APDO(5000, 20000, 1000)>;
+			source-pdos =
+				<PDO_FIXED(5000, 1000, PDO_FIXED_USB_COMM)>;
+
+			altmodes {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				altmode@0 {
+					reg = <0>;
+					svid = <0xff01>;
+					vdo = <0xffffffff>;
+				};
+			};
+		};
 	};
 };
 
 &pinctrl {
+	u-boot,dm-pre-reloc;
 	usb-typec {
+		u-boot,dm-pre-reloc;
 		usbc1_int: usbc1-int {
+			u-boot,dm-pre-reloc;
 			rockchip,pins = <0 RK_PC6 RK_FUNC_GPIO &pcfg_pull_up>;
 		};
 	};
